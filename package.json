{
  "name": "motion-lyte.js",
  "version": "1.1.0",
  "description": "A modular, readable, and maintainable animation framework for the web.",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js",
      "require": "./dist/react.cjs"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    }
  },
  "scripts": {
    "dev": "tsup --watch",
    "build": "tsup",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "keywords": [
    "animation",
    "js",
    "framework",
    "observer",
    "scroll"
  ],
  "author": {
    "name": "CodeWithAsterixh",
    "email": "peter@example.com",
    "url": "https://github.com/CodeWithAsterixh"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CodeWithAsterixh/motion-lyte.js.git"
  },
  "homepage": "https://github.com/CodeWithAsterixh/motion-lyte.js#readme",
  "bugs": {
    "url": "https://github.com/CodeWithAsterixh/motion-lyte.js/issues"
  },
  "funding": [
    {
      "type": "individual",
      "url": "https://github.com/sponsors/CodeWithAsterixh"
    }
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "README.md",
    "usage_guide.md",
    "LICENSE"
  ],
  "devDependencies": {
    "tsup": "^8.0.2",
    "vitest": "^1.4.0",
    "typescript": "^5.4.2",
    "react": "^18.2.0",
    "@types/react": "^18.2.64"
  },
  "peerDependencies": {
    "react": ">=16.8.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}